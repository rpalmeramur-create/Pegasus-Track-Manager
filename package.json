{
  "name": "pegasus-track",
  "private": true,
  "version": "0.5.0",
  "description": "Club management app for Pegasus Track",
  "author": "Pegasus Track",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "predist": "node -e \"const fs=require('fs');try{fs.readdirSync('release').filter(f=>/\\.(exe|blockmap)$/.test(f)).forEach(f=>{try{fs.unlinkSync('release/'+f)}catch(e){}});}catch(e){}\"",
    "dist": "vite build && electron-builder --win --x64",
    "dist:dir": "vite build && electron-builder --win --dir",
    "postinstall": "node scripts/install-bsql-electron.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.383.0",
    "mdb-reader": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.16.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.60.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.pegasustrack.app",
    "productName": "Pegasus Track",
    "copyright": "Copyright © 2026 Pegasus Track",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pegasus Track",
      "deleteAppDataOnUninstall": false,
      "guid": "e7a2c941-4b38-4d9f-a1fc-8e3d6b720c55"
    },
    "publish": {
      "provider": "github",
      "owner": "REPLACE_WITH_GITHUB_USERNAME",
      "repo": "pegasus-track"
    }
  }
}
